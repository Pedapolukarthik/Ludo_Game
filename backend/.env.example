# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/ludo_db

# JWT Secret
JWT_SECRET=super_secret_ludo_jwt_key_123

# LiveKit Credentials (Voice Chat) — must match your LiveKit Cloud project
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# WebSocket URL for clients (wss:// for LiveKit Cloud)
LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_HOST is supported as an alias for LIVEKIT_URL

# Firebase Configuration (Path to Service Account JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
