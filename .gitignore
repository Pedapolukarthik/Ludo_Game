# Root gitignore for Ludo Game monorepo

# Backend
backend/node_modules/
backend/.env
backend/.env.local
backend/*.log
backend/src/config/*-firebase-adminsdk-*.json

# Frontend
frontend/.dart_tool/
frontend/.flutter-plugins-dependencies
frontend/.pub-cache/
frontend/.pub/
frontend/build/
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/
frontend/*.iml
frontend/.idea/

# Common OS files
.DS_Store
Thumbs.db
